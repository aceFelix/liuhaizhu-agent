pipeline {
    agent any

    environment {
        PROJECT_NAME = 'liuhaizhu-backend'
        DEPLOY_DIR = '/path/to/deploy/liuhaizhu-backend'
        IMAGE_NAME = 'liuhaizhu-backend'
        IMAGE_TAG = "${BUILD_NUMBER}"

        SERVER_HOST = credentials('deploy-server-host')
        SERVER_USER = credentials('deploy-server-user')
    }

    stages {
        stage('拉取代码') {
            steps {
                checkout scm
                echo "代码拉取完成，当前构建号: ${BUILD_NUMBER}"
            }
        }

        stage('Maven 编译打包') {
            steps {
                script {
                    echo "开始 Maven 编译..."
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('构建 Docker 镜像') {
            steps {
                script {
                    echo "开始构建 Docker 镜像..."
                    sh """
                        docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('推送镜像（可选）') {
            steps {
                script {
                    echo "镜像构建完成: ${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('部署到服务器') {
            steps {
                script {
                    sshagent(credentials: ['deploy-server-ssh']) {
                        sh """
                            ssh -o StrictHostKeyChecking=yes ${SERVER_USER}@${SERVER_HOST} << 'EOF'
                                cd ${DEPLOY_DIR}

                                docker-compose down || true

                                docker image prune -f

                                docker-compose up -d --build

                                docker-compose ps

                                echo "部署完成!"
EOF
                        """
                    }
                }
            }
        }

        stage('健康检查') {
            steps {
                script {
                    sleep(time: 15, unit: 'SECONDS')
                    sh """
                        curl -f http://${SERVER_HOST}:8000/actuator/health || exit 1
                    """
                    echo "健康检查通过!"
                }
            }
        }
    }

    post {
        success {
            echo "部署成功! 后端服务: http://${SERVER_HOST}:8000"
        }
        failure {
            echo "部署失败，请检查日志"
        }
        always {
            cleanWs()
        }
    }
}
