<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itfelix.liuhaizhuaichat.mapper.TokenUsageMapper">

    <select id="selectByUserIdAndDate" resultType="com.itfelix.liuhaizhuaichat.pojo.entity.TokenUsage">
        SELECT * FROM token_usage
        WHERE user_id = #{userId} AND usage_date = #{usageDate}
        LIMIT 1
    </select>

</mapper>
